
create table public.transaction (
  sn serial not null,
  symbol character varying(10) null,
  pnl double precision null,
  currency character varying(10) null,
  type character varying(20) not null,
  date timestamp without time zone null,
  user_id int not null,
  constraint transaction_pkey primary key (sn)
) TABLESPACE pg_default;

create table public.configuration (
  id bigint generated by default as identity not null,
  name character varying(255) not null,
  value character varying(255) null,
  status boolean not null,
  created_at timestamp with time zone not null default now(),
  last_updated_at timestamp without time zone null,
  constraint configuration_pkey primary key (id)
) TABLESPACE pg_default;

create table public.user_profile (
  id bigserial not null,
  username character varying(100) null,
  email character varying(100) null,
  password character varying(255) null,
  status boolean null,
  created_at date null,
  last_updated_at date null,
  constraint user_profile_pkey primary key (id),
  constraint user_profile_username_key unique (username)
) TABLESPACE pg_default;
